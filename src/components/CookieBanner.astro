---
/**
 * CookieBanner Component
 * Elegant, minimalist cookie consent banner.
 * Design follows the Kadô-kou luxury aesthetic.
 */
---

<div id="cookie-banner" class="fixed bottom-6 right-6 z-10000 max-w-sm w-full px-4 transform translate-y-20 opacity-0 transition-all duration-700 pointer-events-none">
  <div class="bg-white/70 backdrop-blur-2xl border border-white/50 rounded-2xl p-6 shadow-[0_20px_50px_rgba(0,0,0,0.1)] flex flex-col gap-4 pointer-events-auto">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 rounded-xl bg-brushedgold/10 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brushedgold"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"></path><path d="M8.5 8.5v.01"></path><path d="M16 15.5v.01"></path><path d="M12 12v.01"></path><path d="M11 17v.01"></path><path d="M7 14v.01"></path></svg>
      </div>
      <div class="space-y-1">
        <h3 class="text-sm font-black uppercase tracking-widest text-deepblack">Une visite sur mesure</h3>
        <p class="text-xs text-gray-500 font-medium leading-relaxed">
          Comme chaque attention, votre visite est unique. Nous utilisons quelques cookies pour que votre expérience sur Kadô-kou soit aussi fluide qu'élégante.
        </p>
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <button 
        id="cookie-accept"
        class="flex-1 h-10 bg-deepblack text-white rounded-xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-brushedgold transition-all duration-300"
      >
        Accepter
      </button>
      <button 
        id="cookie-refuse"
        class="px-4 h-10 bg-gray-100 text-gray-500 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-gray-200 transition-all duration-300"
      >
        Refuser
      </button>
    </div>
    
    <a href="/cookies" class="text-center text-[9px] text-gray-400 font-bold uppercase tracking-widest hover:text-brushedgold transition-colors">
      En savoir plus sur notre charte
    </a>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const refuseBtn = document.getElementById('cookie-refuse');

  const COOKIE_NAME = 'kadokou_consent';

  function showBanner() {
    if (!localStorage.getItem(COOKIE_NAME)) {
      setTimeout(() => {
        banner?.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
        banner?.classList.add('translate-y-0', 'opacity-100');
      }, 2000);
    }
  }

  function hideBanner() {
    banner?.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
    banner?.classList.remove('translate-y-0', 'opacity-100');
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_NAME, 'accepted');
    hideBanner();
  });

  refuseBtn?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_NAME, 'refused');
    hideBanner();
  });

  // Check on load
  showBanner();
</script>
