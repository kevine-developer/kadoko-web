---
interface Props {
  store: "play" | "apple";
  className?: string;
}

const { store, className = "" } = Astro.props;
---

{
  store === "play" ? (
    <div class={`inline-block ${className}`}>
      <svg
        viewBox="0 0 216 64"
        class="h-10 md:h-12 w-auto"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect width="216" height="64" rx="8" fill="black" />
        <path
          d="M33.7 16.4C33.2 16.9 32.9 17.6 32.9 18.6V45.4C32.9 46.4 33.2 47.1 33.7 47.6L33.8 47.7L48.9 32.6V32.3L33.8 17.2L33.7 17.3V16.4Z"
          fill="#00A0FF"
        />
        <path
          d="M53.9 37.6L48.9 32.6L48.9 32.3L53.9 27.3L54 27.4L60.5 31.1C62.4 32.2 62.4 33.8 60.5 34.9L54 38.6L53.9 38.7V37.6Z"
          fill="#FFCC00"
        />
        <path
          d="M54 38.6L48.9 33.5L33.8 48.6C34.4 49.3 35.5 49.4 36.8 48.7L54 38.6"
          fill="#FF3333"
        />
        <path
          d="M54 27.4L36.8 17.6C35.5 16.9 34.4 17 33.8 17.7L48.9 32.8L54 27.7"
          fill="#48FF48"
        />
        <g fill="white" font-family="Inter, sans-serif">
          <text x="70" y="28" font-size="9" font-weight="600" letter-spacing="0.5">
            GET IT ON
          </text>
          <text x="70" y="48" font-size="18" font-weight="800">
            Google Play
          </text>
        </g>
      </svg>
    </div>
  ) : (
    <div class={`inline-block ${className}`}>
      <svg
        viewBox="0 0 196 64"
        class="h-10 md:h-12 w-auto"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect width="196" height="64" rx="8" fill="black" />
        <path
          d="M37.5 33.1C37.5 28.5 41.3 26.2 41.5 26.1C39.4 23 36.1 22.5 34.9 22.5C31.9 22.2 29.1 24.3 27.6 24.3C26.1 24.3 23.8 22.6 21.3 22.6C18.1 22.6 15.1 24.4 13.5 27.2C10.1 33 12.7 41.5 16 46.3C17.6 48.6 19.5 51.3 21.9 51.2C24.3 51.1 25.2 49.7 28.1 49.7C30.9 49.7 31.8 51.2 34.3 51.1C36.9 51.1 38.5 48.7 40.1 46.4C41.9 43.8 42.6 41.3 42.7 41.2C42.6 41.1 37.5 39.2 37.5 33.1Z"
          fill="white"
        />
        <path
          d="M32.8 19.3C34.1 17.7 35 15.6 34.7 13.5C32.9 13.6 30.7 14.7 29.4 16.2C28.3 17.5 27.3 19.6 27.6 21.7C29.5 21.8 31.6 20.7 32.8 19.3Z"
          fill="white"
        />
        <g fill="white" font-family="Inter, sans-serif">
          <text x="54" y="28" font-size="9" font-weight="600" letter-spacing="0.5">
            Download on the
          </text>
          <text x="54" y="48" font-size="18" font-weight="800">
            App Store
          </text>
        </g>
      </svg>
    </div>
  )
}
