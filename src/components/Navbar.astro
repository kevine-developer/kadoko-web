---
import { LINK_APP_ANDROID } from "../const/constant";
import { Image } from "astro:assets";
import appIcon from "../assets/images/native-app/app-icon.png";
---

<header
  id="main-navbar"
  class="fixed w-full top-0 left-0 z-50 transition-all duration-500 bg-bonesilk/85 backdrop-blur-xl border-b border-black/3 text-deepblack py-4 px-6 md:py-6 md:px-16"
>
  <div class="max-w-[1400px] mx-auto flex justify-between items-center">
    
    <!-- ── LOGO BRANDING ── -->
    <a
      href="/"
      class="group flex items-center gap-3 md:gap-4 transition-all duration-500 focus:outline-none"
      aria-label="Accueil Kadô-Kou (Kadokou)"
    >
      <div class="relative flex items-center justify-center">
        <div
          class="w-10 h-10 md:w-11 md:h-11 bg-white border border-black/5 rounded-full flex items-center justify-center transition-all duration-700 group-hover:scale-105 group-hover:rotate-12 shadow-sm relative z-10"
        >
          <Image
            src={appIcon}
            alt="Logo de l'application Kadô-Kou (Kadokou)"
            width={54}
            height={54}
            class="w-6 h-6 md:w-6.5 md:h-6.5 object-contain rounded-full grayscale group-hover:grayscale-0 transition-all text-transparent"
            aria-hidden="true"
          />
        </div>
        <div
          class="absolute inset-[-4px] border border-brushedgold/30 rounded-full scale-0 group-hover:scale-100 transition-transform duration-700 ease-out z-0"
        >
        </div>
      </div>

      <div class="flex flex-col">
        <div class="flex items-center gap-2">
          <span
            class="text-xs md:text-sm font-bold tracking-[0.3em] uppercase leading-none font-sans"
          >
            Kadô-Kou
          </span>
          <span
            class="text-[7.5px] px-1.5 py-0.5 rounded-full bg-brushedgold/10 text-brushedgold font-black tracking-widest uppercase border border-brushedgold/20"
          >
            Beta
          </span>
        </div>
        <span
          class="text-[9px] font-bold text-brushedgold tracking-[0.25em] uppercase leading-none opacity-0 group-hover:opacity-100 translate-y-1 group-hover:translate-y-0 transition-all duration-500 mt-1 hidden md:block"
          aria-hidden="true"
        >
          L&apos;Art d&apos;Offrir
        </span>
      </div>
    </a>

    <!-- ── NAV LINKS (DESKTOP) ── -->
    <div class="hidden lg:flex items-center gap-10">
      <a
        href="/#receptions"
        class="nav-link text-[10px] font-bold tracking-[0.2em] uppercase text-deepblack/70 hover:text-brushedgold transition-colors duration-300"
      >
        Réceptions
      </a>
      <a
        href="/#fonctionnalites"
        class="nav-link text-[10px] font-bold tracking-[0.2em] uppercase text-deepblack/70 hover:text-brushedgold transition-colors duration-300"
      >
        Fonctionnalités
      </a>
      <a
        href="/news"
        class="nav-link text-[10px] font-bold tracking-[0.2em] uppercase text-deepblack/70 hover:text-brushedgold transition-colors duration-300 relative flex items-center gap-1.5"
      >
        Le Journal
        <span class="w-1.5 h-1.5 rounded-full bg-brushedgold animate-pulse"></span>
      </a>
    </div>

    <!-- ── ACTIONS BUTTONS (DESKTOP) ── -->
    <div class="hidden lg:flex items-center gap-4">
      <button
        data-open-beta
        class="relative overflow-hidden px-6 py-3 text-[10px] font-bold border border-brushedgold/40 text-brushedgold hover:text-white transition-colors duration-500 uppercase tracking-[0.2em] group/beta rounded-sm"
      >
        <span class="relative z-10">Devenir Testeur</span>
        <div
          class="absolute inset-0 bg-brushedgold translate-y-full group-hover/beta:translate-y-0 transition-transform duration-500 ease-out"
        >
        </div>
      </button>

      <a
        href={LINK_APP_ANDROID}
        target="_blank"
        rel="noopener noreferrer"
        class="relative overflow-hidden px-7 py-3 text-[10px] font-bold border border-deepblack text-deepblack hover:text-bonesilk transition-colors duration-500 uppercase tracking-[0.2em] group/btn rounded-sm"
      >
        <span class="relative z-10">L&apos;Application</span>
        <div
          class="absolute inset-0 bg-deepblack translate-y-full group-hover/btn:translate-y-0 transition-transform duration-500 ease-out"
        >
        </div>
      </a>
    </div>

    <!-- ── HAMBURGER BUTTON (MOBILE) ── -->
    <button
      id="hamburger-btn"
      class="lg:hidden p-2 text-deepblack hover:text-brushedgold transition-colors focus:outline-none"
      aria-label="Ouvrir le menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="hamburger-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h16M4 16h16" />
      </svg>
    </button>

  </div>
</header>

<!-- ── MOBILE NAV DRAWER (FULL-SCREEN DE LUXE) ── -->
<div
  id="mobile-drawer"
  class="fixed inset-0 top-[64px] md:top-[72px] bg-bonesilk z-40 transform translate-x-full transition-transform duration-500 ease-out lg:hidden flex flex-col justify-between border-t border-black/5 p-8"
>
  <nav class="flex flex-col space-y-8 pt-8">
    <a
      href="/#receptions"
      class="mobile-nav-link text-2xl font-serif text-deepblack hover:text-brushedgold transition-colors"
    >
      Réceptions
    </a>
    <a
      href="/#fonctionnalites"
      class="mobile-nav-link text-2xl font-serif text-deepblack hover:text-brushedgold transition-colors"
    >
      Fonctionnalités
    </a>
    <a
      href="/news"
      class="mobile-nav-link text-2xl font-serif text-deepblack hover:text-brushedgold transition-colors flex items-center justify-between"
    >
      Le Journal
      <span class="text-[9px] px-2 py-0.5 rounded-full bg-brushedgold text-white font-sans tracking-widest uppercase">Nouveau</span>
    </a>
  </nav>

  <div class="space-y-6 pb-12">
    <button
      data-open-beta
      class="w-full py-4 text-[10px] font-bold border border-brushedgold text-brushedgold text-center uppercase tracking-widest active:bg-brushedgold active:text-white transition-all rounded-sm"
    >
      Devenir Testeur
    </button>
    
    <a
      href={LINK_APP_ANDROID}
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full py-4 bg-deepblack text-white text-[10px] font-bold text-center uppercase tracking-widest active:bg-black transition-all rounded-sm"
    >
      Télécharger l&apos;Application
    </a>

    <div class="text-center pt-4">
      <span class="text-[8px] font-bold tracking-[0.25em] text-coolgrey/40 uppercase">Gastsar • L&apos;Art d&apos;Offrir</span>
    </div>
  </div>
</div>

<script>
  // Dynamic Scroll Effect
  const navbar = document.getElementById("main-navbar");
  
  window.addEventListener("scroll", () => {
    if (window.scrollY > 40) {
      navbar?.classList.remove("py-4", "md:py-6", "bg-bonesilk/85");
      navbar?.classList.add("py-3", "md:py-4", "bg-bonesilk/95", "shadow-xl", "shadow-deepblack/5", "border-b", "border-brushedgold/15");
    } else {
      navbar?.classList.add("py-4", "md:py-6", "bg-bonesilk/85");
      navbar?.classList.remove("py-3", "md:py-4", "bg-bonesilk/95", "shadow-xl", "shadow-deepblack/5", "border-b", "border-brushedgold/15");
    }
  });

  // Mobile Drawer Toggle
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const mobileDrawer = document.getElementById("mobile-drawer");
  const hamburgerPath = document.getElementById("hamburger-path");
  
  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
      mobileDrawer?.classList.remove("translate-x-full");
      hamburgerPath?.setAttribute("d", "M6 18L18 6M6 6l12 12");
      document.body.style.overflow = "hidden";
      // Rendre le header opaque quand le menu est ouvert
      navbar?.classList.add("bg-bonesilk", "border-b", "border-black/5");
      navbar?.classList.remove("bg-bonesilk/85", "bg-bonesilk/95");
    } else {
      mobileDrawer?.classList.add("translate-x-full");
      hamburgerPath?.setAttribute("d", "M4 8h16M4 16h16");
      document.body.style.overflow = "";
      // Rétablir l'état du scroll
      navbar?.classList.remove("bg-bonesilk");
      if (window.scrollY > 40) {
        navbar?.classList.add("bg-bonesilk/95");
      } else {
        navbar?.classList.add("bg-bonesilk/85");
      }
    }
  }

  hamburgerBtn?.addEventListener("click", toggleMenu);

  // Close menu when clicking links
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });
  });
</script>

<style>
  /* Header Links Luxury Underline */
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    width: 0;
    height: 1px;
    bottom: -4px;
    left: 0;
    background-color: #AF9062; /* Brushed Gold */
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
