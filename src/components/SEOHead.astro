---
import { SEO, SITE_URL } from "../const/seo";
import { SystemService } from "../api/services";
import { LINK_APP_ANDROID, LINK_APP_IOS } from "../const/constant";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: "website" | "article" | "profile";
  keywords?: string[];
  imageWidth?: number;
  imageHeight?: number;
}

const {
  title = SEO.defaultTitle,
  description = SEO.defaultDescription,
  image = SEO.defaultImage,
  canonical,
  noindex = false,
  type = "website",
  keywords = SEO.keywords,
  imageWidth,
  imageHeight,
} = Astro.props;

// Récupération dynamique de la configuration des liens de téléchargement de l'application
const config = await SystemService.getConfig();
const playStoreUrl = config?.appLinks?.playStore || LINK_APP_ANDROID;
const appStoreUrl = config?.appLinks?.appStore || LINK_APP_IOS;

const rawCanonicalURL = canonical
  ? new URL(canonical, SITE_URL)
  : new URL(Astro.url.pathname, SITE_URL);

// Ahrefs: Retirer le trailing slash de l'URL canonique (sauf pour la racine pure) pour éviter le duplicate content
const canonicalURL =
  rawCanonicalURL.href.endsWith("/") && rawCanonicalURL.pathname !== "/"
    ? rawCanonicalURL.href.slice(0, -1)
    : rawCanonicalURL.href;

// Résolution robuste de l'image sociale avec fallback
const resolvedImage = (image && image.trim() !== "") ? image : SEO.defaultImage;

let socialImageURL = resolvedImage;
if (!socialImageURL.startsWith("http://") && !socialImageURL.startsWith("https://")) {
  socialImageURL = new URL(resolvedImage, SITE_URL).toString();
}

// Toujours forcer HTTPS pour assurer l'affichage sur WhatsApp, iMessage, Facebook, etc.
if (socialImageURL.startsWith("http://")) {
  socialImageURL = socialImageURL.replace("http://", "https://");
}

// Détection de l'extension pour le type MIME
let ogImageType = "image/jpeg";
const lowerUrl = socialImageURL.toLowerCase();
if (lowerUrl.endsWith(".png")) {
  ogImageType = "image/png";
} else if (lowerUrl.endsWith(".webp")) {
  ogImageType = "image/webp";
} else if (lowerUrl.endsWith(".gif")) {
  ogImageType = "image/gif";
} else if (lowerUrl.endsWith(".svg")) {
  ogImageType = "image/svg+xml";
}

// Choix de la taille de l'image (paysage pour les sites et articles, carré pour les profils)
const ogWidth = imageWidth || (type === "profile" ? 500 : 1200);
const ogHeight = imageHeight || (type === "profile" ? 500 : 630);

// Type de carte Twitter : paysage (summary_large_image) ou carré (summary) pour les profils
const twitterCardType = type === "profile" ? "summary" : "summary_large_image";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="fr" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- Google Play App Indexing (Permet à Google Search d'afficher l'application comme installable avec bouton 'Installer') -->
<link rel="alternate" href="android-app://com.kadokou.devengalere/https/kado-kou.fr/" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords.join(", ")} />
<meta name="author" content="Yves Narson Kevine — Devengalere" />
<link rel="publisher" href={SITE_URL} />
<meta name="publisher" content="Devengalere" />
<meta
  name="robots"
  content={noindex
    ? "noindex, nofollow"
    : "index, follow, max-image-preview:large, max-snippet:-1"}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:secure_url" content={socialImageURL} />
<meta property="og:image:type" content={ogImageType} />
<meta property="og:image:width" content={String(ogWidth)} />
<meta property="og:image:height" content={String(ogHeight)} />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content="fr_FR" />
<meta property="og:site_name" content="Kadô-kou — Liste de Cadeaux" />
<meta property="og:updated_time" content={new Date().toISOString()} />

<!-- Twitter -->
<meta property="twitter:card" content={twitterCardType} />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />
<meta property="twitter:image:alt" content={title} />

<!-- Discord & Slack Theme Color -->
<meta name="theme-color" content="#AF9062" />

<!-- Legacy / Fallbacks (Emails/Yahoo/Outlook) -->
<link rel="image_src" href={socialImageURL} />

<!-- Fonts Preload (Performance) -->
<!-- Georgia est une police système safe, mais si on utilise une webfont : -->
<!-- <link rel="preload" href="/fonts/my-font.woff2" as="font" type="font/woff2" crossorigin /> -->

