---
import {
  LINK_APP_ANDROID,
  LINK_APP_IOS,
  LINK_DEV_EN_GALERE,
  LINK_YVES_NARSON_KEVINE,
  SOCIAL_LINKS,
} from "../const/constant";
import StoreBadges from "./StoreBadges.astro";
import type { PublicConfig } from "../api/services";

interface Props {
  config?: PublicConfig | null;
}

const { config } = Astro.props;
const currentYear = new Date().getFullYear();

// Privilégier les liens configurés dynamiquement
const playStoreUrl = config?.appLinks?.playStore || LINK_APP_ANDROID;
const appStoreUrl = config?.appLinks?.appStore || LINK_APP_IOS;
const instagramUrl = config?.social?.instagram || SOCIAL_LINKS.instagram;
const facebookUrl = config?.social?.facebook || SOCIAL_LINKS.facebook;
---

<footer
  class="bg-deepblack text-bonesilk pt-20 pb-12 px-6 md:px-16 lg:px-24 border-t border-white/5 relative overflow-hidden font-sans"
>
  <!-- Trame de bruit et grains de luxe en arrière-plan -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.02] mix-blend-overlay noise-overlay"
  >
  </div>

  <div class="max-w-[1400px] mx-auto relative z-10">
    
    <!-- ── GRILLE PRINCIPALE DU PIED DE PAGE ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-x-12 gap-y-16 pb-16 border-b border-white/5">
      
      <!-- Colonne 1: Branding & Description (Prend 4 cols sur large) -->
      <div class="lg:col-span-4 space-y-6 flex flex-col items-center md:items-start text-center md:text-left">
        <div>
          <span class="text-2xl md:text-3xl font-serif tracking-tight text-white block mb-1">
            Kadô-Kou
          </span>
          <span class="text-[9px] font-black text-brushedgold tracking-[0.3em] uppercase block">
            L&apos;Art d&apos;Offrir
          </span>
        </div>
        
        <p class="text-xs font-light text-bonesilk/60 leading-relaxed max-w-xs">
          Une expérience de cadeau épurée et raffinée, conçue pour magnifier vos moments uniques de partage.
        </p>

        <!-- Social Icons (Luxury Spaced Text) -->
        <div class="flex flex-wrap items-center gap-5 pt-3">
          <a
            href={SOCIAL_LINKS.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link text-[9px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          >
            LinkedIn
          </a>
          <a
            href={facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link text-[9px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          >
            Facebook
          </a>
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link text-[9px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          >
            Instagram
          </a>
          <a
            href={SOCIAL_LINKS.github}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link text-[9px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          >
            GitHub
          </a>
        </div>
      </div>

      <!-- Colonne 2: Navigation Links (Prend 3 cols sur large) -->
      <div class="lg:col-span-3 space-y-5 text-center md:text-left">
        <h3 class="text-[9px] font-black tracking-[0.25em] uppercase text-white/40">
          Navigation
        </h3>
        <ul class="space-y-3.5">
          <li>
            <a
              href="/#receptions"
              class="footer-nav-link text-xs font-light text-bonesilk/70 hover:text-white transition-colors duration-300"
            >
              Réceptions
            </a>
          </li>
          <li>
            <a
              href="/#fonctionnalites"
              class="footer-nav-link text-xs font-light text-bonesilk/70 hover:text-white transition-colors duration-300"
            >
              Fonctionnalités
            </a>
          </li>
          <li>
            <a
              href="/news"
              class="footer-nav-link text-xs font-semibold text-brushedgold hover:text-white transition-colors duration-300 flex items-center justify-center md:justify-start gap-1.5"
            >
              Le Journal
              <span class="w-1.5 h-1.5 rounded-full bg-brushedgold"></span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Colonne 3: Legal Links (Prend 3 cols sur large) -->
      <div class="lg:col-span-2 space-y-5 text-center md:text-left">
        <h3 class="text-[9px] font-black tracking-[0.25em] uppercase text-white/40">
          Légal
        </h3>
        <ul class="space-y-3.5">
          <li>
            <a
              href="/mentions-legales"
              class="footer-nav-link text-xs font-light text-bonesilk/70 hover:text-white transition-colors duration-300"
            >
              Mentions Légales
            </a>
          </li>
          <li>
            <a
              href="/cgu"
              class="footer-nav-link text-xs font-light text-bonesilk/70 hover:text-white transition-colors duration-300"
            >
              CGU
            </a>
          </li>
          <li>
            <a
              href="/confidentialite"
              class="footer-nav-link text-xs font-light text-bonesilk/70 hover:text-white transition-colors duration-300"
            >
              Confidentialité
            </a>
          </li>
          <li>
            <a
              href="/suppression-compte"
              class="footer-nav-link text-xs font-light text-bonesilk/70 hover:text-white transition-colors duration-300"
            >
              Suppression Compte
            </a>
          </li>
        </ul>
      </div>

      <!-- Colonne 4: Store Badges (Prend 3 cols sur large) -->
      <div class="lg:col-span-3 space-y-5 text-center md:text-left">
        <h3 class="text-[9px] font-black tracking-[0.25em] uppercase text-white/40">
          Disponibilité
        </h3>
        <div class="flex flex-col gap-3.5 justify-center items-center md:items-start">
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-transform duration-300 hover:scale-103 active:scale-97 block"
            aria-label="Télécharger sur Google Play"
          >
            <StoreBadges store="play" className="h-9.5" />
          </a>
          
          {appStoreUrl ? (
            <a
              href={appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-transform duration-300 hover:scale-103 active:scale-97 block"
              aria-label="Télécharger sur l'App Store"
            >
              <StoreBadges store="apple" className="h-9.5" />
            </a>
          ) : (
            <div
              class="opacity-40 grayscale cursor-not-allowed transition-all duration-300"
              title="Bientôt disponible sur l'App Store"
            >
              <StoreBadges store="apple" className="h-9.5" />
            </div>
          )}
        </div>
      </div>

    </div>

    <!-- ── PIED DE PAGE INFÉRIEUR (COPYRIGHT & SIGNATURES) ── -->
    <div class="pt-10 flex flex-col lg:flex-row justify-between items-center gap-6 text-[10px] tracking-widest text-bonesilk/40 uppercase">
      
      <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-brushedgold/40"></span>
          <span>Toulouse • France</span>
        </div>
        <span class="hidden sm:inline text-white/10">|</span>
        <span class="px-2.5 py-0.5 rounded-full border border-white/5 text-[8px] font-black uppercase text-bonesilk/40 bg-white/2">
          Beta Privée
        </span>
      </div>

      <div class="text-center lg:text-right leading-loose">
        <span>&copy; {currentYear} • </span>
        <a
          href={LINK_YVES_NARSON_KEVINE}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-brushedgold transition-colors duration-300 border-b border-transparent hover:border-brushedgold"
        >
          Yves Narson Kevine
        </a>
        <span> par </span>
        <a
          href={LINK_DEV_EN_GALERE}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-brushedgold transition-colors duration-300 border-b border-transparent hover:border-brushedgold"
        >
          Devengalere
        </a>
        <span>. Tous Droits Réservés.</span>
      </div>

    </div>

  </div>
</footer>

<style>
  footer {
    font-feature-settings: "kern" 1, "tnum" 1;
    -webkit-font-smoothing: antialiased;
  }

  /* Luxury underlines for social links */
  .social-link {
    position: relative;
  }
  .social-link::after {
    content: "";
    position: absolute;
    width: 0;
    height: 1px;
    bottom: -2px;
    left: 0;
    background-color: #D4AF37;
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .social-link:hover::after {
    width: 100%;
  }

  /* Elegant slight slide on list link hover */
  .footer-nav-link {
    display: inline-block;
    transition: transform 0.30s ease, color 0.30s ease;
  }
  .footer-nav-link:hover {
    transform: translateX(3px);
  }

  .noise-overlay {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.03) 2px,
        rgba(255, 255, 255, 0.03) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.03) 2px,
        rgba(255, 255, 255, 0.03) 4px
      );
    background-size: 4px 4px;
  }
</style>
