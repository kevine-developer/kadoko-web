---
import {
  LINK_APP_ANDROID,
  LINK_APP_IOS,
  LINK_DEV_EN_GALERE,
  LINK_YVES_NARSON_KEVINE,
  SOCIAL_LINKS,
} from "../const/constant";
import StoreBadges from "./StoreBadges.astro";
import type { PublicConfig } from "../api/services";

interface Props {
  config?: PublicConfig | null;
}

const { config } = Astro.props;
const currentYear = new Date().getFullYear();

// On privilégie les liens de la config API
const playStoreUrl = config?.appLinks?.playStore || LINK_APP_ANDROID;
const appStoreUrl = config?.appLinks?.appStore || LINK_APP_IOS;
const instagramUrl = config?.social?.instagram || SOCIAL_LINKS.instagram;
const facebookUrl = config?.social?.facebook || SOCIAL_LINKS.facebook;
---

<footer
  class="bg-deepblack text-bonesilk py-16 md:py-24 px-6 md:px-20 relative overflow-hidden"
>
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.03] mix-blend-overlay noise-overlay"
  >
  </div>

  <div
    class="max-w-[1400px] mx-auto relative z-10 flex flex-col items-center md:items-start md:flex-row md:justify-between gap-12 mb-12"
  >
    <div class="flex flex-col items-center md:items-start space-y-6 max-w-sm">
      <div class="flex flex-col">
        <span class="text-xl md:text-2xl font-serif italic tracking-tight mb-2"
          >Kadô-Kou</span
        >
        <span
          class="text-xs font-medium text-brushedgold tracking-[0.2em] uppercase leading-none"
          >L'Art d'Offrir</span
        >
      </div>
      <p
        class="text-sm font-light text-bonesilk/60 text-center md:text-left leading-relaxed"
      >
        Réinventez l'art d'offrir et de recevoir avec une application conçue
        pour l'élégance et la simplicité.
      </p>

      <div class="flex flex-wrap items-center justify-center md:justify-start gap-6 pt-4">
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[10px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
        >
          LinkedIn
        </a>
        <a
          href={facebookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[10px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
        >
          Facebook
        </a>
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[10px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
        >
          Instagram
        </a>
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[10px] font-black uppercase tracking-widest text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
        >
          GitHub
        </a>
      </div>
    </div>

    <nav
      class="grid grid-cols-2 md:grid-cols-3 gap-x-10 gap-y-12 md:gap-x-20 text-center md:text-left"
      aria-label="Liens du pied de page"
    >
      <div class="space-y-5">
        <h3
          class="text-xs font-bold tracking-[0.2em] uppercase text-bonesilk/40"
        >
          Navigation
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/#receptions"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Réceptions</a
            >
          </li>
          <li>
            <a
              href="/#fonctionnalites"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Fonctionnalités</a
            >
          </li>
          <li>
            <a
              href="/#manifesto"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Le Manifeste</a
            >
          </li>
        </ul>
      </div>

      <div class="space-y-5">
        <h3
          class="text-xs font-bold tracking-[0.2em] uppercase text-bonesilk/40"
        >
          Légal
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/mentions-legales"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Mentions légales</a
            >
          </li>
          <li>
            <a
              href="/cgu"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Conditions d'utilisation</a
            >
          </li>
          <li>
            <a
              href="/confidentialite"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Politique de confidentialité</a
            >
          </li>
          <li>
            <a
              href="/suppression-compte"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Suppression de compte</a
            >
          </li>
        </ul>
      </div>

      <div class="space-y-5 col-span-2 md:col-span-1">
        <h3
          class="text-xs font-bold tracking-[0.2em] uppercase text-bonesilk/40"
        >
          Disponibilité
        </h3>
        <div class="flex flex-col gap-4">
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-transform duration-300 hover:scale-105 active:scale-95 self-center md:self-start"
            aria-label="Télécharger sur Google Play"
          >
            <StoreBadges store="play" className="h-10" />
          </a>
          {appStoreUrl ? (
            <a
              href={appStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-transform duration-300 hover:scale-105 active:scale-95 self-center md:self-start"
              aria-label="Télécharger sur l'App Store"
            >
              <StoreBadges store="apple" className="h-10" />
            </a>
          ) : (
            <div
              class="opacity-40 grayscale cursor-not-allowed transition-all duration-300 self-center md:self-start"
              title="Bientôt disponible sur l'App Store"
            >
              <StoreBadges store="apple" className="h-10" />
            </div>
          )}
        </div>
      </div>
    </nav>
  </div>

  <div
    class="max-w-[1400px] mx-auto pt-8 border-t border-bonesilk/10 flex flex-col md:flex-row justify-between items-center gap-6 relative z-10"
  >
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2">
        <span class="w-1 h-1 rounded-full bg-brushedgold/40"></span>
        <p class="text-xs tracking-[0.3em] uppercase text-bonesilk/60">
          Toulouse • France
        </p>
      </div>
      <span class="text-[9px] px-2 py-0.5 rounded-full border border-bonesilk/10 text-bonesilk/40 font-bold tracking-widest uppercase">Beta</span>
    </div>
    <p class="text-xs tracking-widest text-bonesilk/40 text-center">
      &copy; {currentYear} — <a
        href={LINK_YVES_NARSON_KEVINE}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brushedgold transition-colors duration-300"
        >Yves Narson Kevine</a
      > par <a
        href={LINK_DEV_EN_GALERE}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brushedgold transition-colors duration-300"
        >Devengalere</a
      >. Tous droits réservés.
    </p>
  </div>
</footer>

<style>
  footer {
    font-feature-settings:
      "kern" 1,
      "tnum" 1;
    -webkit-font-smoothing: antialiased;
  }

  a {
    position: relative;
    display: inline-block;
  }

  a::after {
    content: "";
    position: absolute;
    width: 0;
    height: 1px;
    bottom: -2px;
    left: 0;
    background-color: currentColor;
    transition: width 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  a:hover::after {
    width: 100%;
  }

  .noise-overlay {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.03) 2px,
        rgba(255, 255, 255, 0.03) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.03) 2px,
        rgba(255, 255, 255, 0.03) 4px
      );
    background-size: 4px 4px;
  }
</style>
