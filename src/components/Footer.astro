---
import {
  LINK_APP_ANDROID,
  LINK_DEV_EN_GALERE,
  LINK_YVES_NARSON_KEVINE,
  SOCIAL_LINKS,
} from "../const/constant";
const currentYear = new Date().getFullYear();
---

<footer
  class="bg-deepblack text-bonesilk py-16 md:py-24 px-6 md:px-20 relative overflow-hidden"
>
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.03] mix-blend-overlay noise-overlay"
  >
  </div>

  <div
    class="max-w-[1400px] mx-auto relative z-10 flex flex-col items-center md:items-start md:flex-row md:justify-between gap-12 mb-12"
  >
    <div class="flex flex-col items-center md:items-start space-y-6 max-w-sm">
      <div class="flex flex-col">
        <span class="text-xl md:text-2xl font-serif italic tracking-tight mb-2"
          >Kadô-Kou</span
        >
        <span
          class="text-xs font-medium text-brushedgold tracking-[0.2em] uppercase leading-none"
          >L'Art d'Offrir</span
        >
      </div>
      <p
        class="text-sm font-light text-bonesilk/60 text-center md:text-left leading-relaxed"
      >
        Réinventez l'art d'offrir et de recevoir avec une application conçue
        pour l'élégance et la simplicité.
      </p>

      <div class="flex items-center gap-4 pt-4">
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          aria-label="LinkedIn"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
        </a>
        <a
          href={SOCIAL_LINKS.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          aria-label="Facebook"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"
            ></path>
          </svg>
        </a>
        <a
          href={SOCIAL_LINKS.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          aria-label="Instagram"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.805.249 2.227.412.558.217.951.472 1.37.89.419.419.674.812.89 1.37.164.422.36.164.413 2.227.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.054 1.17-.248 1.805-.413 2.227-.217.558-.472.951-.89 1.37-.419.419-.812.674-1.37.89-.422.164-1.057.36-2.227.413-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.17-.054-1.805-.248-2.227-.413-.558-.217-.951-.472-1.37-.89-.419-.419-.674-.812-.89-1.37-.164-.422-.36-1.057-.413-2.227-.058-1.266-.069-1.646-.069-4.85s.011-3.584.069-4.85c.054-1.17.248-1.805.413-2.227.217-.558.472-.951.89-1.37.419-.419.812-.674 1.37-.89.422-.164 1.057-.36 2.227-.413 1.266-.058 1.646-.069 4.85-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-1.277.057-2.15.26-2.912.557-.787.306-1.454.717-2.118 1.381-.664.664-1.075 1.332-1.381 2.118-.298.763-.501 1.635-.558 2.912-.058 1.28-.072 1.688-.072 4.947s.014 3.667.072 4.947c.057 1.277.26 2.15.558 2.912.306.787.717 1.454 1.381 2.118.664.664 1.332 1.075 2.118 1.381.762.298 1.635.501 2.912.558 1.28.058 1.688.072 4.947.072s3.667-.014 4.947-.072c1.277-.057 2.15-.26 2.912-.558.787-.306 1.454-.717 2.118-1.381.664-.664 1.075-1.332 1.381-2.118.298-.763.501-1.635.558-2.912.058-1.28.072-1.688.072-4.947s-.014-3.667-.072-4.947c-.057-1.277-.26-2.15-.558-2.912-.306-.787-.717-1.454-1.381-2.118-.664-.664-1.075-1.332-1.381-2.118-.298-.763-.501-1.635-.558-2.912-.058-1.28-.072-1.688-.072-4.947s.014-3.667.072-4.947c-.057-1.277-.26-2.15-.558-2.912-.306-.787-.717-1.454-1.381-2.118-.664-.664-1.075-1.332-1.381-2.118-.298-.763-.501-1.635-.558-2.912-.058-1.28-.072-1.688-.072-4.947zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-bonesilk/40 hover:text-brushedgold transition-colors duration-300"
          aria-label="GitHub"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>

    <nav
      class="grid grid-cols-2 md:grid-cols-3 gap-x-10 gap-y-12 md:gap-x-20 text-center md:text-left"
      aria-label="Liens du pied de page"
    >
      <div class="space-y-5">
        <h3
          class="text-xs font-bold tracking-[0.2em] uppercase text-bonesilk/40"
        >
          Navigation
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/#receptions"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Réceptions</a
            >
          </li>
          <li>
            <a
              href="/#fonctionnalites"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Fonctionnalités</a
            >
          </li>
          <li>
            <a
              href="/#manifesto"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Le Manifeste</a
            >
          </li>
        </ul>
      </div>

      <div class="space-y-5">
        <h3
          class="text-xs font-bold tracking-[0.2em] uppercase text-bonesilk/40"
        >
          Légal
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/mentions-legales"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Mentions légales</a
            >
          </li>
          <li>
            <a
              href="/cgu"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Conditions d'utilisation</a
            >
          </li>
          <li>
            <a
              href="/confidentialite"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300"
              >Politique de confidentialité</a
            >
          </li>
        </ul>
      </div>

      <div class="space-y-5 col-span-2 md:col-span-1">
        <h3
          class="text-xs font-bold tracking-[0.2em] uppercase text-bonesilk/40"
        >
          Disponibilité
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href={LINK_APP_ANDROID}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-bonesilk/80 hover:text-brushedgold transition-all duration-300 flex items-center justify-center md:justify-start gap-2"
            >
              Android <svg
                class="w-3 h-3"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                ></path></svg
              >
            </a>
          </li>
          <li>
            <span class="text-sm text-bonesilk/40 cursor-not-allowed"
              >iOS (Prochainement)</span
            >
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <div
    class="max-w-[1400px] mx-auto pt-8 border-t border-bonesilk/10 flex flex-col md:flex-row justify-between items-center gap-6 relative z-10"
  >
    <div class="flex items-center gap-2">
      <span class="w-1 h-1 rounded-full bg-brushedgold/40"></span>
      <p class="text-xs tracking-[0.3em] uppercase text-bonesilk/60">
        Toulouse • France
      </p>
    </div>
    <p class="text-xs tracking-widest text-bonesilk/40 text-center">
      &copy; {currentYear} — <a
        href={LINK_YVES_NARSON_KEVINE}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brushedgold transition-colors duration-300"
        >Yves Narson Kevine</a
      > par <a
        href={LINK_DEV_EN_GALERE}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brushedgold transition-colors duration-300"
        >Devengalere</a
      >. Tous droits réservés.
    </p>
  </div>
</footer>

<style>
  footer {
    font-feature-settings:
      "kern" 1,
      "tnum" 1;
    -webkit-font-smoothing: antialiased;
  }

  a {
    position: relative;
    display: inline-block;
  }

  a::after {
    content: "";
    position: absolute;
    width: 0;
    height: 1px;
    bottom: -2px;
    left: 0;
    background-color: currentColor;
    transition: width 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  a:hover::after {
    width: 100%;
  }

  .noise-overlay {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.03) 2px,
        rgba(255, 255, 255, 0.03) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.03) 2px,
        rgba(255, 255, 255, 0.03) 4px
      );
    background-size: 4px 4px;
  }
</style>
