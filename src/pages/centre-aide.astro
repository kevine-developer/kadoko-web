---
export const prerender = true;
import LegalLayout from "../layouts/LegalLayout.astro";
import { LEGAL_CONTENT } from "../const/legal-data";

const content = LEGAL_CONTENT.help;
const title = `Centre <span class="italic text-coolgrey">d'Aide.</span>`;
const metaTitle = `Centre d'Aide | Kadô-kou`;
const description =
  "Centre d'aide Kadô-kou : FAQ, tutoriels et support pour créer votre wishlist, gérer votre liste de cadeaux et organiser vos événements.";
const lastUpdated = "9 Février 2026";
---

<LegalLayout
  title={title}
  metaTitle={metaTitle}
  description={description}
  subtitle="Support & Assistance"
  lastUpdated={lastUpdated}
>
  <div class="space-y-20">
    {
      content.sections.map((section, idx) => (
        <section class="mb-0">
          {section.title && (
            <h2>
              <span class="text-xs font-bold text-brushedgold/40 tracking-[0.3em] mr-4">
                {String(idx + 1).padStart(2, "0")}
              </span>
              {section.title}
            </h2>
          )}
          <p>{section.body}</p>
        </section>
      ))
    }

    <div
      class="bg-deepblack text-bonesilk p-12 text-center relative overflow-hidden group cursor-default shadow-2xl"
    >
      <div
        class="absolute top-0 left-0 w-full h-1 bg-brushedgold transform origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"
      >
      </div>
      <p
        class="text-xs font-bold tracking-[0.3em] uppercase mb-4 text-white/40"
      >
        Besoin d'assistance directe ?
      </p>
      <a
        href="mailto:yvesnarsonkevine@gmail.com"
        class="text-xl md:text-3xl font-serif italic hover:text-brushedgold transition-colors inline-block pb-2 border-b border-brushedgold/20"
      >
        yvesnarsonkevine@gmail.com
      </a>
    </div>
  </div>
</LegalLayout>

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Comment fonctionnent les Stories sur Kadô-kou ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Les stories sur Kadô-kou sont privées. Elles ne sont visibles que par votre 'Cercle Proche' (vos amis favoris). C'est un espace intime pour partager vos moments sans pression. Pour ajouter un ami à votre cercle, allez sur son profil et cliquez sur 'ajouter à votre cercle'."
        }
      },
      {
        "@type": "Question",
        "name": "Comment ajouter un cadeau à ma wishlist Kadô-kou ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Vous avez deux options : la méthode manuelle (remplissez le titre, le prix et ajoutez une photo) ou la méthode magique (collez simplement le lien d'un site comme Amazon, Vinted ou Etsy et l'application remplira les informations automatiquement)."
        }
      },
      {
        "@type": "Question",
        "name": "Comment créer un groupe ou une réception sur Kadô-kou ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pour organiser un événement (Noël, Anniversaire, Secret Santa) : allez dans l'onglet 'Réceptions', cliquez sur '+' et invitez vos amis. Chaque réception possède un chat dédié et permet de voir les listes de tous les participants."
        }
      },
      {
        "@type": "Question",
        "name": "Comment supprimer mon compte Kadô-kou ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Vous pouvez supprimer votre compte et toutes vos données instantanément depuis : Paramètres > Sécurité > Clôturer le compte."
        }
      }
    ]
  }
</script>
