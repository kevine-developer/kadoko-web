---
export const prerender = true;
import LegalLayout from "../layouts/LegalLayout.astro";
import { LEGAL_CONTENT } from "../const/legal-data";

const content = LEGAL_CONTENT.cgu;
const title = `Conditions Générales <span class="italic text-coolgrey">d'Utilisation.</span>`;
const metaTitle = `Conditions Générales d'Utilisation | Kadô-kou`;
const description =
  "Conditions générales d'utilisation de Kadô-kou, l'application gratuite de wishlist et liste de cadeaux. Découvrez les règles d'utilisation, vos droits et obligations.";
const lastUpdated = "15 Mars 2026";
---

<LegalLayout
  title={title}
  metaTitle={metaTitle}
  description={description}
  subtitle="Contrat d'Usage"
  lastUpdated={lastUpdated}
>
  {
    content.sections.map((section, idx) => (
      <section class="mb-16">
        <h2 id={`section-${idx}`}>
          <span class="text-xs font-bold text-brushedgold/40 tracking-[0.3em] mr-4">
            {String(idx + 1).padStart(2, "0")}
          </span>
          <span class="text-xl  text-deepblack">{section.title}</span>
        </h2>
        <p set:html={section.body} />
      </section>
    ))
  }
</LegalLayout>
