---
export const prerender = true;
import LegalLayout from "../layouts/LegalLayout.astro";
import { LEGAL_CONTENT } from "../const/legal-data";

const content = LEGAL_CONTENT.mentions;
const title = `Mentions <span class="italic text-coolgrey">Légales.</span>`;
const metaTitle = `Mentions Légales | Kadô-kou`;
const description =
  "Mentions légales de Kadô-kou, l'application de wishlist et liste de cadeaux éditée par Devengalere. Éditeur, hébergeur et propriété intellectuelle.";
const lastUpdated = "15 Mars 2026";
---

<LegalLayout
  title={title}
  metaTitle={metaTitle}
  description={description}
  subtitle="Identification Éditeur"
  lastUpdated={lastUpdated}
>
  {
    content.sections.map((section, idx) => (
      <section class="mb-16">
        <h2 id={`section-${idx}`}>
          <span class="text-xs font-bold text-brushedgold/40 tracking-[0.3em] mr-4">
            {String(idx + 1).padStart(2, "0")}
          </span>
          <span class="text-xl  text-deepblack">{section.title}</span>
        </h2>
        <p set:html={section.body} />
      </section>
    ))
  }
</LegalLayout>
