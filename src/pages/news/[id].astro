---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { marked } from "marked";
import { SystemService } from "../../api/services";
import { LINK_APP_ANDROID, SOCIAL_LINKS } from "../../const/constant";

export const prerender = false;

const { id } = Astro.params;

import { apiFetch } from "../../api/client";

// Récupération de tous les articles pour faire correspondre le slug pur en mémoire
const dataList = await apiFetch<{ success: boolean; news: any[] }>("/news").catch(() => null);
const newsList = dataList?.success ? dataList.news : [];

const slugify = (title: string | null | undefined) => {
  if (!title) return "";
  return title
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
};

// Recherche par correspondance de slug pur ou par identifiant brut (pour compatibilité)
let news = newsList.find(
  (item) => slugify(item.title) === id || item.id === id
);

// Fallback : si l'article n'a pas été trouvé (ex: vieil ID spécifique), on tente un fetch direct
if (!news && id) {
  const dataDirect = await apiFetch<{ success: boolean; news: any }>(`/news/${id}`).catch(() => null);
  if (dataDirect?.success) {
    news = dataDirect.news;
  }
}

if (!news) {
  // Rediriger vers la page d'accueil ou une page 404 si l'actualité est introuvable
  return Astro.redirect("/404");
}

const config = await SystemService.getConfig();
const playStoreUrl = config?.appLinks?.playStore || LINK_APP_ANDROID;
const instagramUrl = config?.social?.instagram || SOCIAL_LINKS.instagram;
const facebookUrl = config?.social?.facebook || SOCIAL_LINKS.facebook;

const formatCategory = (cat: string | null) => {
  if (!cat) return "ÉDITORIAL";
  return cat.toUpperCase().split("").join(" ");
};

const formatDate = (dateStr: string) => {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    }).toUpperCase();
  } catch {
    return dateStr;
  }
};

// Nettoyage du Markdown pour les métadonnées de partage (évite d'afficher des ** ou _ dans les aperçus)
const stripMarkdown = (text: string | null) => {
  if (!text) return "";
  return text
    .replace(/(\*\*|__)(.*?)\1/g, "$2")
    .replace(/(\*|_)(.*?)\1/g, "$2")
    .replace(/\[(.*?)\]\(.*?\)/g, "$1")
    .replace(/`{1,3}(.*?)\1/g, "$1")
    .replace(/[#*`~_>-]/g, "")
    .replace(/\s+/g, " ")
    .trim();
};

// Parsing du contenu Markdown (chapeau et corps) pour le web
const summaryHtml = news.summary ? await marked.parse(news.summary) : "";
const contentHtml = news.content ? await marked.parse(news.content) : "";

// Métadonnées SEO dynamiques de luxe
const metaTitle = `${news.title} | Journal Kadô-kou`;
const metaDescription = stripMarkdown(news.summary) || `Découvrez notre dernière publication : "${news.title}" sur Kadô-kou, l'application gratuite de listes de cadeaux.`;
const metaImage = news.imageUrl || "";

// Deep Link pour le bouton d'ouverture dans le mobile
const appScheme = `kadokou://news/${news.id}`;

// Structured Data (JSON-LD)
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": news.title,
  "description": metaDescription,
  "image": [metaImage],
  "datePublished": news.createdAt,
  "dateModified": news.updatedAt,
  "author": {
    "@type": "Organization",
    "name": "Kadô-kou",
    "url": "https://kado-kou.fr"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Kadô-kou",
    "logo": {
      "@type": "ImageObject",
      "url": "https://kado-kou.fr/android-chrome-192x192.png"
    }
  }
};
---

<Layout
  title={metaTitle}
  description={metaDescription}
  image={metaImage}
  noindex={false}
  type="article"
>
  <!-- Données structurées pour le SEO -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <div class="fixed inset-0 pointer-events-none opacity-[0.02] z-50 mix-blend-overlay noise-overlay"></div>

  <main class="min-h-screen bg-bonesilk text-deepblack font-sans pb-24">
    <Navbar />

    <!-- ── Espace de Lecture Éditorial (Style Magazine) ── -->
    <article class="max-w-3xl mx-auto px-6 pt-32 md:pt-40">
      
      <!-- 0. Retour au Journal -->
      <div class="mb-8">
        <a href="/news" class="group inline-flex items-center text-[9px] font-extrabold tracking-[0.25em] text-coolgrey/50 hover:text-brushedgold transition-colors duration-300">
          <svg class="w-3.5 h-3.5 mr-2 transform group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          RETOUR AU JOURNAL
        </a>
      </div>

      <!-- 1. En-tête / Catégorie & Date -->
      <div class="flex items-center space-x-4 mb-6">
        <span class="text-[10px] font-extrabold tracking-[0.25em] text-brushedgold">
          {formatCategory(news.category)}
        </span>
        <div class="w-1.5 h-1.5 rounded-full bg-deepblack/10"></div>
        <span class="text-[10px] font-medium tracking-widest text-coolgrey/60">
          {formatDate(news.createdAt)}
        </span>
      </div>

      <!-- 2. Titre Principal (Serif, Luxe, Spacieux) -->
      <h1 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.15] text-deepblack tracking-tight mb-8">
        {news.title}
      </h1>

      <!-- 3. Image d'Illustration Immersive -->
      {news.imageUrl && (
        <div class="w-full aspect-1200/628 rounded-sm overflow-hidden border border-hairline mb-8 shadow-sm">
          <img 
            src={news.imageUrl} 
            alt={news.title} 
            class="w-full h-full object-cover"
          />
        </div>
      )}

      <!-- 4. Chapeau de l'article (Résumé Mobile / Shortcut en Markdown) -->
      {news.summary && (
        <div class="border-l-2 border-brushedgold pl-6 py-0.5 my-10 prose prose-sm max-w-none text-deepblack/80 font-light leading-relaxed web-article-chapeau" set:html={summaryHtml} />
      )}

      <!-- 5. Séparateur en fil d'or -->
      <div class="w-16 h-px bg-brushedgold/40 mb-10"></div>

      <!-- 6. Corps de l'article Riche (Rendu HTML / Markdown) -->
      <div class="prose prose-sm md:prose-base prose-gray max-w-none text-deepblack/90 leading-relaxed font-light web-article-content" set:html={contentHtml} />

      <!-- 6.5. Réseaux Sociaux & Partage de l'article (Design ultra-épuré) -->
      <div class="mt-12 pt-8 border-t border-black/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-[8px] font-bold tracking-[0.25em] text-coolgrey/40 uppercase">SUIVEZ LE PROJET</span>
          <div class="w-6 h-px bg-black/10 hidden sm:block"></div>
          <div class="flex items-center gap-4">
            <a 
              href={instagramUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-[9px] font-bold tracking-widest text-coolgrey/60 hover:text-brushedgold transition-colors uppercase"
              aria-label="Suivre Kadô-kou sur Instagram"
            >
              Instagram
            </a>
            <a 
              href={facebookUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-[9px] font-bold tracking-widest text-coolgrey/60 hover:text-brushedgold transition-colors uppercase"
              aria-label="Suivre Kadô-kou sur Facebook"
            >
              Facebook
            </a>
            <a 
              href={SOCIAL_LINKS.linkedin} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-[9px] font-bold tracking-widest text-coolgrey/60 hover:text-brushedgold transition-colors uppercase"
              aria-label="Suivre Yves Narson Kevine sur LinkedIn"
            >
              LinkedIn
            </a>
          </div>
        </div>

        <!-- Bouton Partager l'article -->
        <button 
          data-share-article 
          data-share-title={news.title}
          class="group inline-flex items-center gap-2 text-[9px] font-black tracking-widest text-brushedgold uppercase hover:text-deepblack transition-colors w-fit self-start sm:self-auto"
        >
          <span>Partager l&apos;article</span>
          <svg class="w-3.5 h-3.5 transform group-hover:-translate-y-px group-hover:translate-x-px transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 10.742l5.064-2.532m0 0l-5.064-2.532m5.064 2.532l-5.064 2.532m5.064-2.532H19" />
          </svg>
        </button>
      </div>

      <!-- 7. Section d'Ouverture dans l'App (Smart Link Banner) -->
      <div class="mt-16 p-8 bg-white border border-hairline rounded-sm flex flex-col md:flex-row md:items-center justify-between gap-6 shadow-sm">
        <div class="space-y-1">
          <span class="text-[9px] font-black tracking-widest text-brushedgold uppercase block">Expérience Mobile</span>
          <h3 class="font-serif text-lg font-bold text-deepblack">Suivez le guide sur l&apos;application</h3>
          <p class="text-xs text-coolgrey/80 font-light">Accédez à vos listes cadeaux, réceptions et préférences directement.</p>
        </div>
        <a
          href={appScheme}
          data-app-link
          data-store-url={playStoreUrl}
          class="inline-flex items-center justify-center bg-deepblack hover:bg-black text-white px-6 py-3.5 text-[10px] font-bold tracking-widest uppercase transition-all duration-300 active:scale-[0.98]"
        >
          Ouvrir dans l&apos;App
          <svg class="w-4 h-4 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

    </article>
  </main>
</Layout>

<script>
  // Smart App Redirection (Deep-linking fallbacks)
  const appLinkBtn = document.querySelector('[data-app-link]');
  if (appLinkBtn) {
    appLinkBtn.addEventListener('click', (e) => {
      const storeUrl = appLinkBtn.getAttribute('data-store-url') || '';
      const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
      
      if (!isMobile) {
        // Sur ordinateur, on redirige directement vers le store dans un nouvel onglet
        e.preventDefault();
        window.open(storeUrl, '_blank');
      } else {
        // Sur mobile, on lance la tentative d'ouverture d'URI scheme.
        // Si l'application n'est pas installée, la navigation vers le store se déclenche après 1,5s.
        const start = Date.now();
        setTimeout(() => {
          if (Date.now() - start < 2000) {
            window.location.href = storeUrl;
          }
        }, 1500);
      }
    });
  }

  // Bouton Partager l'article via Web Share API
  const shareBtn = document.querySelector('[data-share-article]');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const title = shareBtn.getAttribute('data-share-title') || '';
      try {
        if (navigator.share) {
          await navigator.share({
            title: title,
            text: `Découvrez cet article intéressant sur Kadô-kou : "${title}"`,
            url: window.location.href,
          });
        } else {
          await navigator.clipboard.writeText(window.location.href);
          const span = shareBtn.querySelector('span');
          if (span) {
            const originalText = span.textContent;
            span.textContent = 'LIEN COPIÉ !';
            setTimeout(() => {
              span.textContent = originalText;
            }, 2000);
          }
        }
      } catch (err) {
        // Ignorer l'annulation
      }
    });
  }
</script>

<style is:global>
  /* Styling de luxe pour l'article riche du journal */
  .web-article-content h1, 
  .web-article-content h2, 
  .web-article-content h3 {
    font-family: Georgia, serif;
    color: #1A1A1A;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  .web-article-content h2 {
    font-size: 1.75rem;
  }
  .web-article-content h3 {
    font-size: 1.35rem;
  }
  .web-article-chapeau p {
    font-size: 1.15rem;
    line-height: 1.85;
    font-style: italic;
    color: rgba(26, 26, 26, 0.8);
    margin-bottom: 0;
  }
  .web-article-chapeau strong {
    font-weight: 700;
    color: #1A1A1A;
  }
  .web-article-content p {
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .web-article-content ul {
    list-style-type: none;
    padding-left: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .web-article-content li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .web-article-content li::before {
    content: "◇";
    position: absolute;
    left: 0;
    color: #AF9062;
    font-size: 0.75rem;
    top: 0.15rem;
  }
  .web-article-content strong {
    font-weight: 600;
    color: #1A1A1A;
  }
  .web-article-content a {
    color: #AF9062;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .web-article-content a:hover {
    color: #1A1A1A;
  }
  
  .noise-overlay {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.05) 2px,
        rgba(0, 0, 0, 0.05) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.05) 2px,
        rgba(0, 0, 0, 0.05) 4px
      );
    background-size: 4px 4px;
  }
</style>
