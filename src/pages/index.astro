---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { APP_ICON_URL, LINK_APP_ANDROID } from "../const/constant";
import AppGallery from "../components/AppGallery.astro";
import Navbar from "../components/Navbar.astro";
import Manifesto from "../components/Manifesto.astro";
import Phone3D from "../components/Phone3D.astro";
import ReceptionsShowcase from "../components/ReceptionsShowcase.astro";
import FeaturesGrid from "../components/FeaturesGrid.astro";
import Footer from "../components/Footer.astro";
import StoreBadges from "../components/StoreBadges.astro";
import BetaSignup from "../components/BetaSignup.astro";
import { Image } from "astro:assets";
import { SystemService } from "../api/services";
import { apiFetch } from "../api/client";

import appIcon from "../assets/images/native-app/app-icon.png";
import wishlistsImg from "../assets/images/native-app/wishlists.jpg";
import receptionsImg from "../assets/images/native-app/receptions.jpg";
import sealImg from "../assets/images/native-app/seal.jpg";
import socialImg from "../assets/images/native-app/social.jpg";

const config = await SystemService.getConfig();
const playStoreUrl = config?.appLinks?.playStore || LINK_APP_ANDROID;
const appStoreUrl = config?.appLinks?.appStore || "";

// Récupération dynamique des 3 dernières nouveautés publiées
let homeNews: any[] = [];
try {
  const newsData = await apiFetch<{ success: boolean; news: any[] }>("/news").catch(() => null);
  if (newsData?.success && newsData.news?.length > 0) {
    homeNews = newsData.news.slice(0, 3);
  }
} catch {
  // Ignoré : le fallback sera utilisé
}

// Articles d'actualité fictifs premium si l'API est indisponible ou vide
const fallbackNews = [
  {
    id: "1",
    title: "L'art d'offrir réinventé : L'expérience exclusive Kadô-kou",
    summary: "Découvrez notre manifeste sur l'art délicat d'offrir. Pourquoi chaque attention mérite un écrin digital d'exception, sans bruit ni publicité parasite.",
    imageUrl: wishlistsImg.src,
    category: "ÉDITORIAL",
    createdAt: new Date("2026-05-12").toISOString()
  },
  {
    id: "2",
    title: "Les réceptions d'exception : Guide pratique de l'organisateur",
    summary: "Mariage, baby shower ou anniversaire privé. Notre guide exclusif pour créer des invitations inoubliables et coordonner vos convives avec aisance.",
    imageUrl: receptionsImg.src,
    category: "GUIDE",
    createdAt: new Date("2026-05-08").toISOString()
  },
  {
    id: "3",
    title: "Bêta privée ouverte : Rejoignez le cercle des premiers initiés",
    summary: "L'application mobile ouvre ses portes en version d'essai privée. Comment participer aux tests, suggérer des fonctionnalités et faire partie de l'histoire.",
    imageUrl: socialImg.src,
    category: "ANNONCE",
    createdAt: new Date("2026-05-01").toISOString()
  }
];

const finalNews = homeNews.length > 0 ? homeNews : fallbackNews;
const isFallback = homeNews.length === 0;

const formatCategory = (cat: string | null) => {
  if (!cat) return "ÉDITORIAL";
  return cat.toUpperCase().split("").join(" ");
};

const formatDate = (dateStr: string) => {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    }).toUpperCase();
  } catch {
    return dateStr;
  }
};

const slugify = (title: string | null | undefined, fallbackId: string) => {
  if (!title) return fallbackId;
  const cleanTitle = title
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
  return cleanTitle || fallbackId;
};


const slidesData = [
  {
    id: 1,
    tag: "LISTE DE CADEAUX",
    title: "Votre Collection de Cadeaux",
    description:
      "Créez votre liste de cadeaux personnalisée et transformez vos envies en une collection curatée. Fini les listes en vrac, place à une galerie d'idées cadeaux d'exception.",
    image: wishlistsImg,
  },
  {
    id: 2,
    tag: "ÉVÉNEMENTS",
    title: "Organisez vos Réceptions",
    description:
      "Planifiez vos événements — mariage, anniversaire, naissance — avec des invitations numériques élégantes et une gestion simplifiée de vos convives.",
    image: receptionsImg,
  },
  {
    id: 3,
    tag: "SÉCURITÉ",
    title: "Partage Sécurisé",
    description:
      "Partagez votre liste de cadeaux en toute confiance. Chaque wishlist est protégée par un code d'accès unique pour garantir la confidentialité.",
    image: sealImg,
  },
  {
    id: 4,
    tag: "COMMUNAUTÉ",
    title: "Votre Cercle Intime",
    description:
      "Partagez vos idées cadeaux avec vos proches dans un réseau privé et épuré, conçu pour simplifier l'art d'offrir.",
    image: socialImg,
  },
];
---

<Layout
  title="Kadô-kou (Kadokou) — Application Wishlist & Liste de Cadeaux Gratuite"
  description="Kadô-kou (Kadokou, Kado-kou) est l'app gratuite de wishlist et liste de cadeaux. Créez votre liste de mariage, d'anniversaire et organisez vos événements en toute simplicité."
  keywords={[
    "liste de cadeaux",
    "liste de mariage",
    "liste de naissance",
    "wishlist",
    "idées cadeaux",
    "application liste de cadeaux",
    "organiser un événement",
    "cagnotte",
    "cadeau",
    "anniversaire",
    "créer ma liste",
    "baby shower",
    "kadokou",
    "kado kou",
    "kadôkou",
    "kadô-kou",
    "kado-kou",
  ]}
>
  <div
    class="fixed inset-0 pointer-events-none opacity-[0.03] z-9999 mix-blend-overlay noise-overlay"
  >
  </div>

  <main
    id="main-content"
    class="min-h-screen bg-bonesilk text-deepblack selection:bg-brushedgold selection:text-white overflow-x-hidden"
  >
    <Navbar />

    <header
      class="relative min-h-[90vh] md:min-h-screen flex flex-col justify-center px-6 md:px-20 pt-28 pb-20 overflow-hidden"
    >
      <div
        class="max-w-[1400px] w-full mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center relative z-10"
      >
        <div
          class="md:col-span-7 flex flex-col justify-center space-y-10 md:space-y-12 text-center md:text-left"
        >
          <h1 class="sr-only">
            Kadô-kou (Kadokou, Kado-kou) : L'application de référence pour votre liste de cadeaux,
            liste de mariage et liste de naissance
          </h1>

          <div
            class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-deepblack/3 border border-deepblack/5 animate-fade-in [animation-delay:200ms] opacity-0 fill-mode-forwards w-fit mx-auto md:mx-0"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brushedgold opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-brushedgold"
              ></span>
            </span>
            <span
              class="text-[10px] font-bold tracking-[0.2em] uppercase text-deepblack/60"
              >Beta Test en cours</span
            >
          </div>
          <div
            aria-hidden="true"
            class="text-4xl md:text-6xl lg:text-[7rem] font-serif leading-[1.1] tracking-tight text-deepblack"
          >
            <span class="block overflow-hidden">
              <span
                class="block animate-slide-up-fade [animation-delay:400ms] opacity-0 fill-mode-forwards"
                >L'élégance</span
              >
            </span>
            <span class="block overflow-hidden">
              <span
                class="block animate-slide-up-fade [animation-delay:550ms] opacity-0 fill-mode-forwards italic text-brushedgold"
                >du geste.</span
              >
            </span>
            <span class="block overflow-hidden">
              <span
                class="block animate-slide-up-fade [animation-delay:700ms] opacity-0 fill-mode-forwards"
                >Le plaisir d'offrir.</span
              >
            </span>
          </div>

          <div class="max-w-md mx-auto md:mx-0 overflow-hidden">
            <p
              class="text-sm md:text-base text-coolgrey/80 font-light leading-relaxed animate-slide-up-fade [animation-delay:900ms] opacity-0 fill-mode-forwards"
            >
              Kadô-kou réinvente la liste de cadeaux et l'art de recevoir. Créez
              votre collection de cadeaux, trouvez l'idée cadeau parfaite et
              organisez vos événements avec une application conçue pour ceux qui
              considèrent que chaque attention mérite un écrin d'exception.
            </p>
          </div>

          <div
            class="flex flex-row items-center justify-center md:justify-start gap-4 md:gap-6 pt-4 animate-fade-in [animation-delay:1.1s] opacity-0 fill-mode-forwards"
          >
            <a
              href={playStoreUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-transform duration-300 hover:scale-105 active:scale-95"
              aria-label="Télécharger sur Google Play"
            >
              <StoreBadges store="play" />
            </a>
            {appStoreUrl ? (
              <a
                href={appStoreUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="transition-transform duration-300 hover:scale-105 active:scale-95"
                aria-label="Télécharger sur l'App Store"
              >
                <StoreBadges store="apple" />
              </a>
            ) : (
              <div
                class="opacity-40 grayscale cursor-not-allowed transition-all duration-300"
                title="Bientôt disponible sur l'App Store"
              >
                <StoreBadges store="apple" />
              </div>
            )}
          </div>
        </div>

        <!-- Téléphone 3D Premium -->
        <div
          class="md:col-span-5 relative h-[45vh] md:h-[70vh] flex items-center justify-center my-16 md:my-0"
        >
          <Phone3D
            logoSrc={appIcon}
            className="opacity-0 translate-y-10 reveal-on-scroll transition-all duration-1000 ease-out"
          />
        </div>
      </div>
    </header>

    <!-- La Galerie — Collection de Cadeaux -->
    <section
      class="relative z-20 bg-white"
      aria-label="Fonctionnalités de la liste de cadeaux Kadô-kou"
    >
      <!-- Bandeau de transition -->
      <div
        class="py-4 border-y border-hairline flex justify-between px-6 bg-bonesilk overflow-hidden"
      >
        <h2 class="sr-only">
          Fonctionnalités : Liste de mariage, liste de naissance, anniversaire
          et wishlist en ligne
        </h2>
        <!-- Conteneur de défilement infini -->
        <div class="flex whitespace-nowrap overflow-hidden">
          <div
            class="flex gap-12 animate-marquee items-center text-xs font-bold tracking-[0.3em] uppercase text-coolgrey/60 px-6"
          >
            <span>Liste de Cadeaux</span><span>—</span><span>Idées Cadeaux</span
            ><span>—</span><span>Événements & Réceptions</span><span>—</span
            ><span>Wishlist en Ligne</span><span>—</span><span
              >Collection Curatée</span
            ><span>—</span>
          </div>
          <div
            class="flex gap-12 animate-marquee items-center text-xs font-bold tracking-[0.3em] uppercase text-coolgrey/60 px-6"
            aria-hidden="true"
          >
            <span>Liste de Cadeaux</span><span>—</span><span>Idées Cadeaux</span
            ><span>—</span><span>Événements & Réceptions</span><span>—</span
            ><span>Wishlist en Ligne</span><span>—</span><span
              >Collection Curatée</span
            ><span>—</span>
          </div>
        </div>
      </div>

      <AppGallery slides={slidesData} />
    </section>

    <!-- Prestations Réception -->
    <ReceptionsShowcase />

    <!-- Features -->
    <FeaturesGrid />

    <!-- Nouveautés Grid Section -->
    <section 
      class="py-16 md:py-20 px-6 md:px-12 bg-bonesilk/40 border-t border-black/3 relative"
      aria-label="Dernières actualités et nouveautés"
    >
      <div class="max-w-6xl mx-auto">
        <!-- En-tête de section style éditorial ultra-raffiné -->
        <div class="text-center md:text-left space-y-2 max-w-xl reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out">
          <span class="text-[8px] font-bold tracking-[0.4em] text-brushedgold uppercase block">PERSPECTIVES & CRÉATIONS</span>
          <h2 class="text-2xl md:text-3xl font-serif text-deepblack font-light leading-tight tracking-tight">
            Les dernières <span class="italic text-brushedgold font-normal">Nouveautés.</span>
          </h2>
          <p class="text-[11px] md:text-xs text-coolgrey/70 font-light leading-relaxed">
            L&apos;art d&apos;offrir se réinvente au quotidien. Suivez nos récits d&apos;inspiration, guides pratiques et coulisses du projet.
          </p>
        </div>

        <!-- Grille des articles compacte et réactive -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mt-12">
          {finalNews.map((item, idx) => (
            <a 
              href={isFallback ? "/news" : `/news/${slugify(item.title, item.id)}`}
              class="group flex flex-col space-y-4 cursor-pointer reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out"
              style={`transition-delay: ${idx * 100}ms`}
            >
              {item.imageUrl && (
                <div class="aspect-16/10 w-full rounded-sm overflow-hidden border border-black/5 shadow-[0_2px_10px_-4px_rgba(0,0,0,0.03)] relative bg-white">
                  <img 
                    src={item.imageUrl} 
                    alt={item.title} 
                    class="w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-102"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-deepblack/2 group-hover:opacity-0 transition-opacity duration-500"></div>
                </div>
              )}
              
              <div class="flex flex-col space-y-2.5">
                <div class="flex items-center space-x-2">
                  <span class="text-[8px] font-bold tracking-[0.2em] text-brushedgold uppercase">
                    {formatCategory(item.category)}
                  </span>
                  <span class="text-[8px] text-coolgrey/30">•</span>
                  <span class="text-[8px] font-medium tracking-[0.2em] text-coolgrey/40 uppercase">
                    {formatDate(item.createdAt)}
                  </span>
                </div>
                
                <h3 class="text-sm font-serif font-medium text-deepblack leading-snug tracking-tight group-hover:text-brushedgold transition-colors duration-300 line-clamp-2">
                  {item.title}
                </h3>
                
                <p class="text-[11px] text-coolgrey/80 leading-relaxed font-light line-clamp-2">
                  {item.summary}
                </p>
                
                <div class="inline-flex items-center gap-1.5 text-[8px] font-bold tracking-[0.25em] uppercase text-brushedgold pt-1 group-hover:text-deepblack transition-colors duration-300 w-fit">
                  <span>LIRE L'ARTICLE</span>
                  <svg class="w-2.5 h-2.5 transform group-hover:translate-x-0.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.5 4.5L19 10m0 0l-5.5 5.5M19 10H5" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Bouton Voir Plus compact et épuré -->
        <div class="flex justify-center mt-12 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out">
          <a
            href="/news"
            class="group inline-flex items-center justify-center border border-deepblack/5 hover:border-deepblack/15 bg-white hover:bg-deepblack hover:text-white px-6 py-3 text-[9px] font-bold tracking-[0.2em] uppercase transition-all duration-300 active:scale-[0.98] shadow-sm rounded-sm"
          >
            Découvrir le Journal
            <svg class="w-3.5 h-3.5 ml-2.5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <Manifesto />
    
    <!-- Modals -->
    <BetaSignup />
  </main>
</Layout>

<script>
  // Intersection Observer pour les animations au scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-10");
          entry.target.classList.add("opacity-100", "translate-y-0");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );

  document
    .querySelectorAll(".reveal-on-scroll")
    .forEach((el) => observer.observe(el));

  // Redirection intelligente pour mobile
  function openApp() {
    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    if (!isMobile) return;

    const localExpUrl = "exp://192.168.1.100:8081/--/verify-success";
    const prodSchemeUrl = "kadokou://verify-success";

    // Tentative d'ouverture
    window.location.href = localExpUrl;
    setTimeout(function () {
      window.location.href = prodSchemeUrl;
    }, 500);
  }

  // Tenter l'ouverture si on vient d'un email
  window.addEventListener("load", () => {
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get("from") === "email" || window.location.hash === "#open") {
      openApp();
    }
  });
</script>

<style>
  /* Ajout des keyframes pour les nouvelles animations */
  @keyframes slide-up-fade {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .animate-slide-up-fade {
    animation: slide-up-fade 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes float-slow {
    0%,
    100% {
      transform: translateY(0) rotateY(12deg) rotateZ(3deg);
    }
    50% {
      transform: translateY(-15px) rotateY(12deg) rotateZ(3deg);
    }
  }

  .animate-float-slow {
    animation: float-slow 6s ease-in-out infinite;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .animate-marquee {
    animation: marquee 30s linear infinite;
  }

  /* Utilitaires 3D */
  .perspective-1000 {
    perspective: 1000px;
  }

  .rotate-y-12 {
    transform: rotateY(-12deg);
  }

  .rotate-z-3 {
    transform: rotateZ(3deg);
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade-in {
    animation: fade-in 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .noise-overlay {
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.05) 2px,
        rgba(0, 0, 0, 0.05) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.05) 2px,
        rgba(0, 0, 0, 0.05) 4px
      );
    background-size: 4px 4px;
  }
</style>
